# LexAfrica Backend - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# Environnement
ENVIRONMENT=development

# CORS (séparer par virgule pour plusieurs origines)
CORS_ORIGINS=http://localhost:3000

# Base de données (Phase 2 - laisser vide pour Phase 1)
DATABASE_URL=postgresql://user:password@host:5432/lexafrica

# JWT (Phase 2)
JWT_SECRET_KEY=votre_cle_secrete_tres_longue_au_moins_32_caracteres
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# CinetPay (Phase 4)
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_NOTIFY_URL=https://api.lexafrica.com/api/v1/payments/webhook
CINETPAY_RETURN_URL=https://lexafrica.com/dashboard

# Supabase Storage (Phase 3)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
STORAGE_BUCKET=lexafrica-documents
